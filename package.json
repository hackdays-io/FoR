{
  "name": "for-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "FoR monorepo managed with pnpm",
  "scripts": {
    "frontend": "pnpm --filter frontend",
    "contract": "pnpm --filter contract",
    "indexer": "pnpm --filter @for/indexer",
    "dev:node": "pnpm --filter @for/contract dev",
    "dev:frontend": "pnpm --filter frontend dev",
    "dev:graph": "docker compose up -d",
    "dev:graph:down": "docker compose down",
    "dev:graph:clean": "docker compose down -v && rm -rf data/"
  },
  "keywords": [
    "pnpm",
    "monorepo",
    "frontend",
    "contract"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18.18.0"
  },
  "packageManager": "pnpm@9.12.0",
  "devDependencies": {
    "@biomejs/biome": "^2.3.7"
  }
}
